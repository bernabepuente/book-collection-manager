# Apache Maven Wrapper startup batch script, version 3.3.2

set -e

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(pwd)}"
WRAPPERDIR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper"
WRAPPER_JAR="$WRAPPERDIR/maven-wrapper.jar"
WRAPPER_PROPERTIES="$WRAPPERDIR/maven-wrapper.properties"

if [ -r "$WRAPPER_PROPERTIES" ]; then
  DISTRIBUTION_URL=$(grep '^distributionUrl=' "$WRAPPER_PROPERTIES" | cut -d= -f2-)
fi

WRAPPER_JAR_URL=$(grep '^wrapperUrl=' "$WRAPPER_PROPERTIES" | cut -d= -f2-)
WRAPPER_JAR_URL="${WRAPPER_JAR_URL:-https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar}"

if [ ! -e "$WRAPPER_JAR" ]; then
  echo "Downloading $WRAPPER_JAR_URL"
  if command -v curl > /dev/null; then
    curl -o "$WRAPPER_JAR" "$WRAPPER_JAR_URL"
  elif command -v wget > /dev/null; then
    wget -O "$WRAPPER_JAR" "$WRAPPER_JAR_URL"
  else
    echo "Cannot find curl or wget to download maven-wrapper.jar" >&2
    exit 1
  fi
fi

JAVA_EXEC="${JAVA_HOME:+$JAVA_HOME/bin/}java"

exec "$JAVA_EXEC" \
  $MAVEN_OPTS \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  org.apache.maven.wrapper.MavenWrapperMain \
  "$@"
